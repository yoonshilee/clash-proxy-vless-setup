# Copy this file to server/config/setup.conf and edit the values you want to override.
# server/install.sh, server/uninstall.sh, and client/render-client-configs.sh all read from it.

# Server-side settings
XRAY_PORT=443
PUBLIC_IP=
REALITY_SERVER_NAME=www.cloudflare.com
REALITY_DEST=www.cloudflare.com:443
REALITY_FINGERPRINT=chrome
SUBSCRIPTION_PORT=8443

# Use AUTO_GENERATE to let install.sh create a random value.
XRAY_UUID=AUTO_GENERATE
REALITY_PRIVATE_KEY=AUTO_GENERATE
REALITY_PUBLIC_KEY=AUTO_GENERATE
REALITY_SHORT_ID=AUTO_GENERATE
SUB_TOKEN=AUTO_GENERATE

# Client example settings
CLASH_PROXY_NAME=example-vless-reality
CLASH_MIXED_PORT=7897
CLASH_GLOBAL_MODE=global
CLASH_RULE_MODE=rule
